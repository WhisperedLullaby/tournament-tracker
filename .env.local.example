# Database Configuration
# Use the Supabase transaction pooler URL for better reliability
DATABASE_URL=postgresql://postgres.PROJECT_REF:PASSWORD@aws-1-us-east-2.pooler.supabase.com:6543/postgres

# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Cloudflare Turnstile (CAPTCHA)
# Get these from: https://dash.cloudflare.com/
NEXT_PUBLIC_TURNSTILE_SITE_KEY=your_turnstile_site_key_here
TURNSTILE_SECRET_KEY=your_turnstile_secret_key_here

# Resend (Email Service)
# Get this from: https://resend.com/
RESEND_API_KEY=re_xxxxxxxxxxxx

# Cron secret — Bearer token that guards /api/cron/* (the daily reminder job).
# Vercel sends this automatically when CRON_SECRET is set in the Vercel project;
# set the same value here only if you want to invoke the cron route locally.
CRON_SECRET=your_random_cron_secret_here

# Dev-only: enables an email/password sign-in form on /auth/signin for testing
# with seeded users (e.g. test1@test.com / test123). Leave unset in production.
# NEXT_PUBLIC_ENABLE_TEST_LOGIN=true

# Dev-only: Supabase service role key, used by scripts/* for admin tasks
# (creating test users, schema migrations). Bypasses RLS — keep secret.
# SUPABASE_SERVICE_ROLE_KEY=eyJ...
